APP_NAME=MedReport AgentRAG
API_PREFIX=/api/v1

# Fill this only in your local .env. Do not commit real keys.
LLM_API_KEY=sk-your-key-here
LLM_BASE_URL=https://api.siliconflow.cn/v1
LLM_CHAT_MODEL=Qwen/Qwen2.5-7B-Instruct

DATASET_TRAIN_DIR=./dataset/df/train
DATASET_TEST_DIR=./dataset/df/test
DATA_TRAIN_DIR=./data/df/train
DATA_TEST_DIR=./data/df/test
DATASET_KG_PATH=./dataset/knowledge graph of DDXPlus.xlsx
DATA_KG_PATH=./data/kg/knowledge graph of DDXPlus.xlsx
VECTOR_BASE_DIR=./vector_db
UPLOAD_DIR=./data/uploads
REPORT_DIR=./data/reports

DEFAULT_TOP_K=5
DEFAULT_KG_TOP_K=8
DEFAULT_TOP_K_PER_SOURCE=2
FORCE_MOCK_LLM=false
USE_MULTI_VECTOR=true
