# ============================================================
# MedRAG DDXPlus — .gitignore
# ============================================================

# 敏感文件（包含 API Key，绝对不能上传）
authentication.py
.env

# Local runtime data in the document-aligned project layout
data/raw/**
data/processed/**
data/df/**
data/kg/**
data/embeddings_cache/**
data/uploads/**
data/reports/**
!data/raw/
!data/raw/.gitkeep
!data/raw/ddxplus_raw/
!data/raw/ddxplus_raw/.gitkeep
!data/raw/health_reports/
!data/raw/health_reports/.gitkeep
!data/processed/
!data/processed/.gitkeep
!data/df/
!data/df/.gitkeep
!data/df/train/
!data/df/train/.gitkeep
!data/df/test/
!data/df/test/.gitkeep
!data/kg/
!data/kg/.gitkeep
!data/embeddings_cache/
!data/embeddings_cache/.gitkeep
!data/uploads/
!data/uploads/.gitkeep
!data/reports/
!data/reports/.gitkeep

# 数据集（需要用户自行准备）
dataset/df/
dataset/ddxplus_raw/
dataset/*.csv
dataset/*.xlsx

# Embedding 缓存（避免上传几十 MB 的 .npy）
dataset/document_embeddings_*
*.npy

# 本地模型缓存
models/

# KG Embedding 缓存
Embeddings_saved/

# Python 字节码
__pycache__/
__pycache__/**/*
*.pyc
*.pyo

# macOS
.DS_Store

# IDE
.idea/
.claude/

# 备份文件夹（含旧版 authentication.py，不应上传）
备份原文件/
第二次备份原文件/

# Jupyter
.ipynb_checkpoints/

# 虚拟环境
venv/
.venv/
env/

# 外部数据集（大文件，用户自行准备）
external_datasets/

# 向量库（构建产物，用户自行构建）
vector_db/

# 输出结果（每次运行都会生成）
test_results_*.csv

# Phase-2 runtime artifacts
storage/embeddings/*
storage/indexes/*
storage/results/*
storage/metrics/*
!storage/embeddings/.gitkeep
!storage/indexes/.gitkeep
!storage/results/.gitkeep
!storage/metrics/.gitkeep

# Local sharing bundles
shared_packages/
